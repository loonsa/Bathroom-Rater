<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4EFE8"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add a New Bathroom"
            android:textSize="25sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp" />

        <EditText
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name (e.g. Behind the Elevator Restrooms)"
            android:inputType="text" />

        <EditText
            android:id="@+id/building"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Building (e.g. McKeldin Library)"
            android:inputType="text" />

        <EditText
            android:id="@+id/floor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Floor Number (e.g. 1)"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/latitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitude (e.g. 38.9897)"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/longitude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitude (e.g. -76.9378)"
            android:inputType="numberDecimal|numberSigned" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/is_gender_neutral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Is it Gender Neutral?"
            android:layout_marginTop="15dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/is_ada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Is it ADA Compliant?"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/add_bathroom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Bathroom"
            android:layout_marginTop="25dp"
            app:backgroundTint="#17236A" />

        <Button
            android:id="@+id/back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Back"
            android:textColor="#111"
            android:paddingLeft="60dp"
            android:paddingRight="60dp"
            app:backgroundTint="#5571788F"
            android:layout_gravity="center_horizontal"/>
    </LinearLayout>
</ScrollView>